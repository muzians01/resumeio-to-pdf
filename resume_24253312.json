rap</li>\n  <li><strong>Azure Cloud:</strong> Microsoft Azure - Web Apps, Queues, Blob Storage, Logic Apps, Apps Insights, Service Bus, Cosmos DB, AAD, Key-Vault, Managed Identity.</li>\n  <li><strong>AWS: </strong>AWS EC2, Auto Scaling Groups (ASG), CloudWatch</li>\n  <li><strong>DevOps:</strong> Azure DevOps, <strong>Docker</strong>, <strong>AKS</strong>, CI/CD Pipelines, AWS CodePipeline.</li>\n  <li><strong>Tools:</strong> Git, Bitbucket, Jenkins, Swagger, JIRA</li>\n  <li><strong>Architecture:</strong> <strong>Micro-services</strong>, SOLID Principles, Design Patterns</li>\n</ul>\n<p><br></p>\n<h3><strong>Achievement</strong></h3>\n<p><strong>UEPL Excellence Award (2023)</strong> – Recognized for exceptional contribution in reverse engineering and successfully compiling the legacy NRS (Qterics) platform, enabling direct issues resolution and supportability.</p>\n<p><br></p>\n<h3><strong>Certifications</strong></h3>\n<ul>\n  <li>Microsoft Certified: Azure Developer Associate (AZ-204)</li>\n  <li>Microsoft Certified: DevOps Engineer Expert (AZ-400)</li>\n  <li>Microsoft Certified: Azure Fundamentals (AZ-900)</li>\n</ul>","template":"dublin","sectionsOrder":["profile","workExperiences","educations","socialProfiles","skills","languages","hobbies","accomplishments","publications","technicalProficiencyCategories"],"color":"#242935","spacing":0.0,"version":"aaf9df6435","secureId":"tiuJjdO6b","locale":"en-US","gender":null,"namePronunciation":null,"addressPronunciation":null,"resumeSubmissionDate":null,"married":false,"numberOfDependents":null,"spouseObligation":false,"commutingTime":null,"spaceForPersonalRequests":null,"referencesUponRequest":false,"hideSkillLevel":true,"sectionTitles":{},"showPrefillResumeModal":null,"motivation":null,"pr":null,"qualifications":null,"technicalSkills":null,"skillsDescription":null,"companyName":null,"jobTitle":null,"linkedin":null,"powerStatement":null,"accomplishments":null,"publications":null,"updatedAt":"2026-06-06T13:21:06+02:00",